# Subplayer Mode (STANDALONE | PROXY)
# STANDALONE: Original mode with login screen and username/password
# PROXY: Pre-configured mode that bypasses login and uses the built-in proxy
REACT_APP_MODE=PROXY

# --- Required only for PROXY mode backend ---
SUBSONIC_URL=http://your-subsonic-server:4040
SUBSONIC_USER=your_username
SUBSONIC_PASS=your_password
